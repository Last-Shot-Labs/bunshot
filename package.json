{
  "name": "@lastshotlabs/bunshot",
  "version": "0.0.16",
  "description": "Batteries-included Bun + Hono API framework — auth, sessions, rate limiting, WebSocket, queues, and OpenAPI docs out of the box",
  "repository": {
    "type": "git",
    "url": "https://github.com/Last-Shot-Labs/bunshot.git"
  },
  "license": "MIT",
  "keywords": [
    "bun",
    "hono",
    "api",
    "framework",
    "auth",
    "websocket",
    "openapi"
  ],
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./mongo": {
      "import": "./dist/entrypoints/mongo.js",
      "types": "./dist/entrypoints/mongo.d.ts"
    },
    "./redis": {
      "import": "./dist/entrypoints/redis.js",
      "types": "./dist/entrypoints/redis.d.ts"
    },
    "./queue": {
      "import": "./dist/entrypoints/queue.js",
      "types": "./dist/entrypoints/queue.d.ts"
    },
    "./docs/*": "./docs/sections/*"
  },
  "bin": {
    "bunshot": "./dist/cli.js"
  },
  "files": [
    "dist",
    "docs/sections"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json && bun build src/cli.ts --outdir dist --minify --target bun",
    "prepublishOnly": "bun run build",
    "release": "npm version patch && npm publish",
    "dev": "bun --watch src/index.ts",
    "start": "bun src/index.ts",
    "readme": "bun docs/build-readme.ts",
    "readme:npm": "bun docs/build-readme.ts npm",
    "test": "bun test"
  },
  "dependencies": {
    "@hono/zod-openapi": "1.2.2",
    "@scalar/hono-api-reference": "0.10.0",
    "arctic": "^3.7.0",
    "jose": "6.2.0"
  },
  "peerDependencies": {
    "hono": ">=4.12 <5",
    "zod": ">=4.0 <5",
    "mongoose": ">=9.0 <10",
    "ioredis": ">=5.0 <6",
    "bullmq": ">=5.0 <6",
    "otpauth": ">=9.0 <10",
    "@simplewebauthn/server": ">=10.0.0"
  },
  "peerDependenciesMeta": {
    "mongoose": {
      "optional": true
    },
    "ioredis": {
      "optional": true
    },
    "bullmq": {
      "optional": true
    },
    "otpauth": {
      "optional": true
    },
    "@simplewebauthn/server": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/bun": "1.3.10",
    "bullmq": "^5.70.4",
    "hono": ">=4.12",
    "ioredis": "5.10.0",
    "mongoose": "9.2.4",
    "otpauth": "^9.5.0",
    "tsc-alias": "^1.8.16",
    "typescript": "^5.9.3",
    "zod": ">=4.0",
    "@simplewebauthn/server": "^13.1.1"
  },
  "publishConfig": {
    "access": "public"
  }
}